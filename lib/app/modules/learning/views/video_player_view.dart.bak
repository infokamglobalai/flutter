  Widget _buildResourcesTab(BuildContext context, bool isMobile) {
    return Obx(() {
      final documents = controller.documents;
      final selectedDoc = controller.selectedDocument.value;

      if (selectedDoc != null) {
        return Column(
          children: [
            _buildResourceViewerHeader(selectedDoc, isMobile),
            Expanded(child: _buildDocumentViewer(context, selectedDoc)),
          ],
        );
      }

      return Container(
        color: Colors.grey[50],
        child: SingleChildScrollView(
          padding: EdgeInsets.all(isMobile ? 16 : 24),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              _buildResourcesHeader(isMobile),
              const SizedBox(height: 24),
              _buildResourcesStats(isMobile),
              const SizedBox(height: 24),
              _buildResourceCategories(documents, isMobile),
            ],
          ),
        ),
      );
    });
  }

