                        decoration: InputDecoration(
                          hintText: isSubmitted
                              ? 'Exercise submitted - View only'
                              : 'Write your answer here...',
                          hintStyle: TextStyle(
                            color: Colors.grey[400],
                            fontSize: isMobile ? 10 : 13,
                          ),
                          border: InputBorder.none,
                          contentPadding: EdgeInsets.zero,
                        ),
                      ),
                    ),
                  ),
                  // Submission info or button
                  Container(
                    padding: EdgeInsets.symmetric(
                      horizontal: isMobile ? 10 : 16,
                      vertical: isMobile ? 8 : 12,
                    ),
                    decoration: BoxDecoration(
                      color: isSubmitted
                          ? Colors.green.withOpacity(0.05)
                          : Colors.grey[50],
                      borderRadius: BorderRadius.only(
                        bottomLeft: Radius.circular(isMobile ? 12 : 16),
                        bottomRight: Radius.circular(isMobile ? 12 : 16),
                      ),
                      border: Border(
                        top: BorderSide(
                          color: AppTheme.primaryColor.withOpacity(0.1),
                          width: 1,
                        ),
                      ),
                    ),
                    child: isSubmitted
                        ? Row(
                            mainAxisSize: MainAxisSize.min,
                            children: [
                              Icon(
                                Icons.check_circle,
                                color: Colors.green,
                                size: isMobile ? 14 : 20,
                              ),
                              SizedBox(width: isMobile ? 6 : 12),
                              Expanded(
                                child: Column(
                                  crossAxisAlignment: CrossAxisAlignment.start,
                                  mainAxisSize: MainAxisSize.min,
                                  children: [
                                    Text(
                                      'Submitted',
                                      style: TextStyle(
                                        fontSize: isMobile ? 10 : 13,
                                        fontWeight: FontWeight.bold,
                                        color: Colors.green[700],
                                      ),
                                    ),
                                    if (controller.submittedAt.value != null &&
                                        !isMobile)
                                      Text(
                                        _formatDate(
                                          controller.submittedAt.value!,
                                        ),
                                        style: TextStyle(
                                          fontSize: 9,
                                          color: Colors.grey[600],
                                        ),
                                      ),
                                  ],
                                ),
                              ),
                            ],
                          )
                        : Row(
                            mainAxisSize: MainAxisSize.min,
                            children: [
                              if (!isMobile)
                                Expanded(
                                  child: Text(
                                    'Practice only',
                                    style: TextStyle(
                                      fontSize: 9,
                                      color: Colors.grey[600],
                                    ),
                                  ),
                                ),
                              SizedBox(width: isMobile ? 0 : 8),
                              Obx(
                                () => ElevatedButton(
                                  onPressed:
                                      controller.isSubmittingExercise.value
                                      ? null
                                      : controller.submitExercise,
                                  style: ElevatedButton.styleFrom(
                                    backgroundColor: AppTheme.primaryColor,
                                    foregroundColor: Colors.white,
                                    padding: EdgeInsets.symmetric(
                                      horizontal: isMobile ? 16 : 20,
                                      vertical: isMobile ? 8 : 12,
                                    ),
                                    shape: RoundedRectangleBorder(
                                      borderRadius: BorderRadius.circular(
                                        isMobile ? 8 : 10,
                                      ),
                                    ),
                                    minimumSize: Size.zero,
                                  ),
                                  child: controller.isSubmittingExercise.value
                                      ? SizedBox(
                                          width: isMobile ? 12 : 16,
                                          height: isMobile ? 12 : 16,
                                          child:
                                              const CircularProgressIndicator(
                                                strokeWidth: 2,
                                                color: Colors.white,
                                              ),
                                        )
                                      : Row(
                                          mainAxisSize: MainAxisSize.min,
                                          children: [
                                            Icon(
                                              Icons.send_rounded,
                                              size: isMobile ? 12 : 16,
                                            ),
                                            SizedBox(width: isMobile ? 4 : 6),
                                            Text(
                                              'Submit',
                                              style: TextStyle(
                                                fontSize: isMobile ? 10 : 13,
                                                fontWeight: FontWeight.bold,
                                              ),
                                            ),
                                          ],
                                        ),
                                ),
                              ),
                            ],
                          ),
                  ),
                ],
              ),
            ),
          ),
        ],
      );
    });
  }

  String _formatDate(DateTime date) {
    return '${date.day}/${date.month}/${date.year} at ${date.hour}:${date.minute.toString().padLeft(2, '0')}';
  }

  IconData _getDocumentIcon(String iconType) {
    switch (iconType) {
      case 'notes':
        return Icons.notes_rounded;
      case 'problems':
        return Icons.assignment_rounded;
      case 'solutions':
        return Icons.check_circle_outline_rounded;
      case 'reference':
        return Icons.bookmark_outline_rounded;
      default:
        return Icons.description_outlined;
    }
  }

  String _formatDuration(Duration duration) {
    final minutes = duration.inMinutes.remainder(60).toString().padLeft(2, '0');
    final seconds = duration.inSeconds.remainder(60).toString().padLeft(2, '0');
    return '$minutes:$seconds';
  }
}
