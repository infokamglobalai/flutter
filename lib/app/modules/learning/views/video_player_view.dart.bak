  Widget _buildExerciseStats(Map<String, dynamic> exercise, bool isMobile) {
    return Row(
      children: [
        Expanded(
          child: _buildExerciseStatCard(
            Icons.help_outline,
            '${exercise['questions'] ?? 5}',
            'Questions',
            const Color(0xFF3B82F6),
            isMobile,
          ),
        ),
        const SizedBox(width: 12),
        Expanded(
          child: _buildExerciseStatCard(
            Icons.schedule,
            '${exercise['timeLimit'] ?? 30} min',
            'Time Limit',
            const Color(0xFFF59E0B),
            isMobile,
          ),
        ),
        const SizedBox(width: 12),
        Expanded(
          child: _buildExerciseStatCard(
            Icons.grade,
            '${exercise['maxScore'] ?? 100}',
            'Max Score',
            const Color(0xFF8B5CF6),
            isMobile,
          ),
        ),
      ],
    );
  }

  Widget _buildExerciseStatCard(
    IconData icon,
    String value,
    String label,
    Color color,
    bool isMobile,
  ) {
    return Container(
      padding: EdgeInsets.all(isMobile ? 16 : 20),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(16),
        border: Border.all(color: color.withOpacity(0.2)),
        boxShadow: [
          BoxShadow(
            color: color.withOpacity(0.1),
            blurRadius: 12,
            offset: const Offset(0, 4),
          ),
        ],
      ),
      child: Column(
        children: [
          Container(
            padding: const EdgeInsets.all(10),
            decoration: BoxDecoration(
              gradient: LinearGradient(
                colors: [color.withOpacity(0.15), color.withOpacity(0.08)],
              ),
              shape: BoxShape.circle,
            ),
            child: Icon(icon, color: color, size: isMobile ? 22 : 26),
          ),
          const SizedBox(height: 12),
          Text(
            value,
            style: TextStyle(
              fontSize: isMobile ? 18 : 22,
              fontWeight: FontWeight.bold,
              color: color,
            ),
          ),
          const SizedBox(height: 4),
          Text(
            label,
            style: TextStyle(
              fontSize: isMobile ? 11 : 12,
              color: Colors.grey[600],
              fontWeight: FontWeight.w600,
            ),
          ),
        ],
      ),
    );
  }

