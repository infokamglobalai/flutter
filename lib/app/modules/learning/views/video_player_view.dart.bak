  Widget _buildStatItem(
    IconData icon,
    String value,
    String label,
    Color color,
    bool isMobile,
  ) {
    return Column(
      children: [
        Icon(icon, color: color, size: isMobile ? 24 : 28),
        const SizedBox(height: 8),
        Text(
          value,
          style: TextStyle(
            fontSize: isMobile ? 18 : 22,
            fontWeight: FontWeight.bold,
            color: color,
          ),
